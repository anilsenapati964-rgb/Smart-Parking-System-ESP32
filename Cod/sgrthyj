#define BLYNK_AUTH_TOKEN "YOUR_AUTH_TOKEN"
char ssid[] = "YOUR_WIFI_NAME";
char pass[] = "YOUR_WIFI_PASSWORD";

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <ESP32Servo.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// -------- WiFi --------
char ssid[] = "CirkitWifi";
char pass[] = "";

// -------- OLED --------
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// -------- IR Sensors --------
#define IR1 13
#define IR2 12
#define IR3 14

// -------- Servo --------
#define SERVO_PIN 4

// -------- LEDs --------
#define G1 5
#define R1 6

#define G2 7
#define R2 15

#define G3 16
#define R3 17

Servo gateServo;

void setup() {

  pinMode(IR1, INPUT);
  pinMode(IR2, INPUT);
  pinMode(IR3, INPUT);

  pinMode(G1, OUTPUT);
  pinMode(R1, OUTPUT);

  pinMode(G2, OUTPUT);
  pinMode(R2, OUTPUT);

  pinMode(G3, OUTPUT);
  pinMode(R3, OUTPUT);

  // OLED
  Wire.begin(8, 9);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    while (1);
  }

  // Servo
  gateServo.attach(SERVO_PIN);
  gateServo.write(0);

  // Blynk
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
}

void loop() {

  Blynk.run();

  // HIGH = Car Present
  bool slot1 = (digitalRead(IR1) == HIGH);
  bool slot2 = (digitalRead(IR2) == HIGH);
  bool slot3 = (digitalRead(IR3) == HIGH);

  int available = 3;

  if (slot1) available--;
  if (slot2) available--;
  if (slot3) available--;

  // -------- LEDs --------
  digitalWrite(G1, !slot1);
  digitalWrite(R1, slot1);

  digitalWrite(G2, !slot2);
  digitalWrite(R2, slot2);

  digitalWrite(G3, !slot3);
  digitalWrite(R3, slot3);

  // -------- Servo --------
  if (available > 0) {
    gateServo.write(0);      // Gate Open
    Blynk.virtualWrite(V4, "OPEN");
  } else {
    gateServo.write(90);     // Gate Closed
    Blynk.virtualWrite(V4, "CLOSED");
  }

  // -------- OLED --------
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  display.setCursor(0, 0);
  display.println("SMART PARKING");

  display.setCursor(0, 18);
  display.print("S1: ");
  display.println(slot1 ? "FULL" : "EMPTY");

  display.setCursor(0, 30);
  display.print("S2: ");
  display.println(slot2 ? "FULL" : "EMPTY");

  display.setCursor(0, 42);
  display.print("S3: ");
  display.println(slot3 ? "FULL" : "EMPTY");

  display.setCursor(0, 54);
  display.print("FREE: ");
  display.print(available);

  display.display();

  // -------- Blynk --------

  // Slot LEDs
  Blynk.virtualWrite(V0, !slot1);
  Blynk.virtualWrite(V1, !slot2);
  Blynk.virtualWrite(V2, !slot3);

  // Free Slots Gauge + Chart
  Blynk.virtualWrite(V3, available);

  delay(300);
}
